# Environment variables template
# Copy this file to .env.local and replace with actual values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/estimate_management_dev?schema=public"

# Auth.js
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Dev signin defaults (development only)
# NEXT_PUBLIC_DEV_LOGIN_EMAIL=employee1@example.com
# NEXT_PUBLIC_DEV_LOGIN_PASSWORD=pass123!
