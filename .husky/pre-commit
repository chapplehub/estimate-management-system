# Skip pre-commit checks if no code files are staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Only run checks when code files are staged
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '^(src/|prisma/|[^/]*\.(ts|js|mjs|tsx|jsx)$)' || true)

if [ -z "$CODE_FILES" ]; then
  echo "📝 No code changes detected. Skipping lint-staged and tests."
  exit 0
fi

pnpm lint-staged

# 変更されたコードに関連するテストだけ実行する（import グラフを逆引き）
# 全体型チェック（tsc）とフルスイートは pre-push で担保する
echo "$CODE_FILES" | xargs pnpm vitest related --run
