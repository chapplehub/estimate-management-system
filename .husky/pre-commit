# Skip pre-commit checks if only docs/markdown files are staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

# Check if all staged files match docs-only patterns (docs/** or *.md at root)
NON_DOC_FILES=$(echo "$STAGED_FILES" | grep -vE '^(docs/|\.claude/|\.serena/|[^/]*\.md$)' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

if [ -z "$NON_DOC_FILES" ]; then
  echo "📝 Docs-only changes detected. Skipping lint-staged, tsc, and tests."
  exit 0
fi

pnpm lint-staged
pnpm tsc --noEmit
pnpm test
