{
  "model": "opus",
  "alwaysThinkingEnabled": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \"unknown\"); echo \"Current branch: $BRANCH\"; if [ \"$BRANCH\" = \"main\" ] || [ \"$BRANCH\" = \"master\" ] || [ \"$BRANCH\" = \"develop\" ]; then echo \"\"; echo \"⚠️  WARNING: You are on the $BRANCH branch.\"; echo \"For parallel development, consider using git worktree:\"; echo \"  git worktree add ../$(basename $PWD)-<task-name> -b <branch-name>\"; echo \"\"; fi'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo \"unknown\"); INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r \".tool_input.command // empty\" 2>/dev/null); if [ -z \"$CMD\" ]; then exit 0; fi; if echo \"$CMD\" | grep -qE \"git\\s+(push|commit)\"; then if [ \"$BRANCH\" = \"main\" ] || [ \"$BRANCH\" = \"master\" ] || [ \"$BRANCH\" = \"develop\" ]; then echo \"❌ ERROR: git push/commit to $BRANCH branch is blocked.\" >&2; echo \"Please use a feature branch or git worktree for development.\" >&2; exit 2; fi; fi'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run start:*)",
      "Bash(npm start:*)",

      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(vitest:*)",

      "Bash(npm run lint:*)",
      "Bash(eslint:*)",

      "Bash(npm run db:studio:*)",
      "Bash(npm run db:generate:*)",
      "Bash(prisma generate:*)",
      "Bash(prisma studio:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree list:*)",
      "Bash(git worktree remove:*)",

      "Bash(npm install:*)",
      "Bash(npm ci:*)",

      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue close:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",

      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",

      "Read(/web/**)",
      "Write(/web/src/**)",
      "Edit(/web/src/**)",
      "Write(/learn/**)",
      "Edit(/learn/**)",

      "SlashCommand(/learn:*)"
    ],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",

      "Read(.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",

      "Write(.env*)",
      "Write(**/secrets/**)",

      "Bash(npm run db:migrate:*)",
      "Bash(npm run db:push:*)",
      "Bash(npm run db:seed:*)",
      "Bash(prisma migrate:*)",
      "Bash(prisma db push:*)"
    ]
  }
}
