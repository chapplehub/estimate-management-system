{
  "cleanupPeriodDays": 365,
  "permissions": {
    "allow": [
      "Bash(pnpm dev*)",
      "Bash(pnpm build*)",
      "Bash(pnpm start*)",
      "Bash(pnpm test*)",
      "Bash(vitest*)",
      "Bash(pnpm lint*)",
      "Bash(eslint*)",
      "Bash(pnpm db:studio*)",
      "Bash(pnpm db:generate*)",
      "Bash(prisma generate*)",
      "Bash(prisma studio*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git checkout*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git worktree add*)",
      "Bash(git worktree list*)",
      "Bash(git worktree remove*)",
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue create*)",
      "Bash(gh issue comment*)",
      "Bash(gh issue close*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh label list*)",
      "Bash(cat *)",
      "Bash(tree*)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Write(/src/**)",
      "Edit(/src/**)",
      "Write(/docs/**)",
      "Edit(/docs/**)",
      "Write(/learning/**)",
      "Edit(/learning/**)",
      "SlashCommand(/learn*)",
      "WebSearch",
      "mcp__context7",
      "mcp__serena",
      "mcp__playwright"
    ],
    "deny": [
      "Bash(git rebase*)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit *--amend*)",
      "Bash(git commit --amend*)",
      "Bash(git commit *--force*)",
      "Bash(git commit --force*)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Read(.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(pnpm db:migrate*)",
      "Bash(pnpm db:push*)",
      "Bash(pnpm db:seed*)",
      "Bash(prisma migrate*)",
      "Bash(prisma db push*)"
    ]
  },
  "model": "opus",
  "defaultMode": "acceptEdits",
  "sandbox": {
    "enabled": false,
    "excludedCommands" :["pnpm", "vitest"],
    "filesystem": {
      "allowWrite": [".", "~/.local/share/pnpm", "~/.npm"],
      "denyWrite": [".env", ".env.local", "config/production.json"],
      "denyRead": ["~/.ssh"],
      "allowRead": ["."]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "github.com",
        "*.github.com",
        "api.github.com"
      ],
      "deniedDomains": [] 
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-notify-completion.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-ask-notify-question.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-branch-safety.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-plan-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-plan-file-check.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pipe-stage-permissions.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify-permission-prompt.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-bash-commit-fail-check.sh"
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-worktree-setup.sh"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true
}
